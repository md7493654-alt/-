rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Primitives ---
    function isSignedIn() { return request.auth != null; }
    function isVerifiedEmail() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'md7493654@gmail.com'
      ); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 100
        && data.role in ['buyer', 'seller']
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500))
        && (data.nid == null || (data.nid is string && data.nid.size() <= 50))
        && (data.idPhotoURL == null || (data.idPhotoURL is string && data.idPhotoURL.size() <= 500))
        && (data.isVerified == false) // Cannot self-verify
        && data.createdAt == request.time;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() <= 100
        && data.description is string && data.description.size() <= 2000
        && data.price is number && data.price >= 0
        && data.category is string && data.category.size() <= 50
        && data.sellerId == request.auth.uid
        && data.status == 'pending'
        && data.createdAt == request.time;
    }

    function isValidMessage(data) {
      return data.senderId == request.auth.uid
        && data.text is string && data.text.size() <= 1000
        && data.createdAt == request.time;
    }

    // --- Match Blocks ---

    match /system/health { 
      allow get: if true; 
    }

    // USERS
    match /users/{userId} {
      allow get: if isSignedIn(); // Public profile check is handled by fields
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid; // Only list yourself
      
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(userId) && isValidUser(incoming()) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'nid', 'idPhotoURL']))
      );
      
      // Admin update for verification
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['isVerified', 'role']);
    }

    // PRODUCTS
    match /products/{productId} {
      // Public can see approved products
      allow get: if existing().status == 'approved' || (isSignedIn() && existing().sellerId == request.auth.uid) || isAdmin();
      allow list: if resource.data.status == 'approved' || (isSignedIn() && resource.data.sellerId == request.auth.uid) || isAdmin();

      allow create: if isVerifiedEmail() && isValidProduct(incoming());
      
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(existing().sellerId) && 
         incoming().status == 'pending' && // Re-submit for approval if edited? Or keep status.
         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'category', 'images', 'status']))
      );

      // Admin approval
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
      
      allow delete: if isAdmin() || (isSignedIn() && isOwner(existing().sellerId));
    }

    // CONVERSATIONS
    match /conversations/{convId} {
      allow read: if isSignedIn() && request.auth.uid in existing().participants;
      
      allow create: if isSignedIn() && request.auth.uid in incoming().participants && incoming().participants.size() == 2;
      
      allow update: if isSignedIn() && request.auth.uid in existing().participants;

      match /messages/{msgId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants && isValidMessage(incoming());
      }
    }

    // ADMINS
    match /admins/{uid} {
      allow read: if isSignedIn();
    }
  }
}
